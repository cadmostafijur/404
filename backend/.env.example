# Copy to .env for local dev. These are the defaults already baked into
# settings.py, so .env is optional locally — it only matters once you
# want to override something (e.g. testing prod-like settings).
#
# NOTE: Render does NOT read this file. In production, set these same
# keys directly in the Render dashboard (Environment tab) with your
# real deployed URLs.

DJANGO_SECRET_KEY=change-me-generate-a-real-random-value
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Production example (set these on Render instead, not here):
# DJANGO_DEBUG=False
# DJANGO_ALLOWED_HOSTS=your-service.onrender.com
# CORS_ALLOWED_ORIGINS=https://your-frontend.vercel.app
